# project

- label: project has Rust Cargo workspace skeleton and gitignore
  command: test -f Cargo.toml && test -f .gitignore && test -f src/main.rs && test -f src/lib.rs
  tags: [implemented]

# product

- label: Cargo package and binary are named openpuffer
  command: grep -qE 'name = "openpuffer"' Cargo.toml && test -f target/release/openpuffer || cargo build --release -q && test -f target/release/openpuffer
  tags: [implemented]
- label: core API targets turbopuffer-compatible write and query semantics
  command: grep -q "turbopuffer-compatible" src/lib.rs && test -f docs/ARCHITECTURE.md
  tags: [implemented]

# domain

- label: a Namespace is an isolated document collection keyed by name under S3 prefix openpuffer/{name}/
  command: grep -q 'ROOT_PREFIX' src/models.rs && test -f src/meta.rs && test -f src/namespace.rs
  tags: [implemented]
- label: a Document is a row with id and JSON attributes including optional vector and text fields
  command: grep -q 'struct Document' src/models.rs && grep -q 'attributes' src/models.rs
  tags: [implemented]
- label: durable state is WAL segments meta.json and index segments only with no per-doc docs/{id}.json
  command: test -f src/wal.rs && grep -q 'docs/{id}.json' docs/ARCHITECTURE.md && grep -q 'assert_wal_layout_after_write' tests/integration_s3.rs
  tags: [implemented]

# architecture

- label: release build produces one openpuffer static binary with no sidecar requirement
  command: cargo build --release -q && test -x target/release/openpuffer
  tags: [implemented]
- label: server persists all durable namespace state to S3-compatible object storage not embedded databases
  command: grep -rq 'put_object' src/ && ! grep -rq 'sqlite\|rocksdb\|sled' src/ && grep -q 'wal/' docs/ARCHITECTURE.md
  tags: [implemented]
- label: multiple serve instances can read the same bucket with optional local index cache only
  command: grep -q 'stateless' src/lib.rs && test -f src/cache.rs && test -f src/view_cache.rs
  tags: [implemented]
- label: meta.json and indexer commits use S3 conditional PUT If-Match and If-None-Match CAS
  command: grep -q 'if_match' src/namespace.rs && grep -q 'if_none_match' src/namespace.rs && grep -q 'if_match' src/indexer.rs
  tags: [implemented]
- label: writes append bincode WAL files at openpuffer/{ns}/wal/{seq:08}.bin before HTTP ACK
  command: test -f src/wal.rs && test -f src/buffer.rs && grep -q 'wal/{seq:08}.bin' src/wal.rs
  tags: [implemented]
- label: background indexer merges WAL into FTS vector and filter segments under openpuffer/{ns}/index/
  command: test -f src/indexer.rs && test -f src/index/fts.rs && test -f src/index/vector.rs && test -f src/index/filter.rs
  tags: [implemented]
- label: per-namespace commit_lock serializes concurrent WAL appends and meta CAS for one namespace
  command: test -f src/commit_lock.rs && grep -q 'commit_lock' src/namespace.rs
  tags: [implemented]
- label: vector ANN index uses two-level centroids-l0.bin and centroids-l1-* segments on S3
  command: grep -q 'CentroidIndexL0' src/index/vector.rs && grep -q 'centroids-l1' src/index/vector.rs && cargo test --lib recall_at_10_1k_docs_32dim_above_point_seven -q
  tags: [implemented]
- label: WAL compaction writes wal/snapshot.bin CAS wal_snapshot_seq and prunes superseded wal segments
  command: test -f src/wal_compaction.rs && grep -q 'maybe_compact_wal' src/indexer.rs
  tags: [implemented]
- label: cold namespace load uses s3_batch two-round parallel fetch with storage_roundtrips in query performance
  command: test -f src/s3_batch.rs && grep -q 'fetch_cold_index_artifacts' src/s3_batch.rs && cargo test --lib query_performance_includes_storage_roundtrips -q
  tags: [implemented]

# write

- label: write path group-commits upserts patches and deletes into one WalEntry per flush
  command: grep -q 'WalEntry' src/wal.rs && grep -q 'group-commit' src/buffer.rs
  tags: [implemented]
- label: write accepts patch_rows and patch_columns merged on WAL replay
  command: grep -q 'patch_rows' src/models.rs && grep -q 'patches' src/wal.rs
  tags: [implemented]
- label: write accepts schema hints merged into NamespaceMeta.schema on commit
  command: grep -q 'merge_schema' src/schema.rs && grep -q 'schema' src/models.rs
  tags: [implemented]
- label: write accepts delete_by_filter resolving ids via filter index and WAL tail
  command: grep -q 'delete_by_filter' src/models.rs && grep -q 'matching_doc_ids_for_filter' src/search.rs
  tags: [implemented]
- label: write accepts patch_by_filter resolving ids via filter index and WAL tail with patch attrs
  command: grep -q 'patch_by_filter' src/models.rs && grep -q 'resolve_ids_for_filter' src/storage.rs
  tags: [implemented]
- label: write enforces at most one durable WAL commit per namespace per second
  command: grep -q 'min_commit_interval' src/buffer.rs && grep -q 'wal_commit_rate_max_one_per_second' tests/integration_s3.rs
  tags: [implemented]
- label: write accepts copy_from_namespace to clone source S3 prefix into empty destination
  command: grep -q 'copy_from_namespace' src/models.rs && grep -q 'copy_from_namespace' src/storage.rs
  tags: [implemented]
- label: write accepts branch_from_namespace instant COW clone via S3 copy into empty destination
  command: grep -q 'branch_from_namespace' src/models.rs && grep -q 'branch_from_namespace' src/storage.rs
  tags: [implemented]
- label: write accepts distance_metric cosine_distance or euclidean_squared stored in meta.json
  command: grep -q 'distance_metric' src/meta.rs && grep -q 'resolve_distance_metric' src/meta.rs
  tags: [implemented]
- label: write accepts return_affected_ids returning upserted_ids and deleted_ids lists
  command: grep -q 'return_affected_ids' src/models.rs && grep -q 'upserted_ids' src/models.rs
  tags: [implemented]
- label: write accepts upsert_condition evaluated against committed WAL and pending buffer
  command: grep -q 'upsert_condition' src/models.rs && grep -q 'overlay_pending_writes' src/buffer.rs
  tags: [implemented]

# query

- label: query accepts rank_by vector ANN over indexed centroid clusters plus unindexed WAL tail
  command: cargo test --lib cosine_identical -q && test -f src/index/vector.rs
  tags: [implemented]
- label: query accepts rank_by BM25 over FTS inverted index postings
  command: cargo test --lib bm25_indexed_query_returns_top_doc -q
  tags: [implemented]
- label: query accepts hybrid rank_by Sum and Product combining vector and BM25
  command: grep -q 'Ranker::Sum' src/search.rs && grep -q 'Ranker::Product' src/search.rs
  tags: [implemented]
- label: query accepts attribute filters intersected before scoring
  command: test -f src/filter.rs && grep -q 'eval_filter' src/search.rs
  tags: [implemented]
- label: query accepts order_by field and asc or desc as tie-break after rank_by scoring
  command: grep -q 'parse_order_by' src/search.rs && cargo test --lib order_by_priority_desc_breaks_score_ties -q
  tags: [implemented]
- label: query returns performance.candidates_ratio for indexed ANN regression guard
  command: cargo test --lib indexed_vector_candidates_ratio_under_ten_percent -q
  tags: [implemented]
- label: query accepts include_vectors and vector_encoding float or base64 on responses
  command: grep -q 'include_vectors' src/models.rs && grep -q 'vector_encoding' src/vector_encoding.rs
  tags: [implemented]
- label: write accepts base64-encoded f32 little-endian vectors decoded on upsert
  command: grep -q 'normalize_document_vectors' src/vector_encoding.rs && grep -q 'decode_base64_f32_le' src/vector_encoding.rs
  tags: [implemented]
- label: schema accepts [N]f16 vector type for half-precision index clusters
  command: grep -q 'VectorElement::F16' src/schema.rs && grep -q 'vector_element' src/index/vector.rs
  tags: [implemented]
- label: write accepts base64-encoded f16 little-endian vectors when schema is [N]f16
  command: grep -q 'decode_base64_f16_le' src/vector_encoding.rs && cargo test --lib base64_f16_roundtrip -q
  tags: [implemented]
- label: ANN cluster segments store packed f16 and score with f32 compute at query time
  command: grep -q 'vector_f16' src/index/vector.rs && cargo test --lib f16_ann_finds_nearest_neighbor -q
  tags: [implemented]
- label: perf test on 5k docs asserts candidates_ratio stays below 12 percent
  command: cargo test -F perf --test perf_namespace -q
  tags: [implemented]

# stack

- label: implementation language is Rust edition 2021
  command: grep -q 'edition = "2021"' Cargo.toml
  tags: [implemented]

# cli

- label: openpuffer serve binds HTTP and loads S3 settings from env and flags
  command: cargo build --release -q && target/release/openpuffer --help 2>&1 | grep -q serve
  tags: [implemented]
- label: serve accepts --s3-endpoint --s3-bucket --s3-region --s3-access-key --s3-secret-key --cache-dir and OPENPUFFER_S3_* env vars
  command: target/release/openpuffer serve --help 2>&1 | grep -q s3-endpoint && target/release/openpuffer serve --help 2>&1 | grep -q cache-dir
  tags: [implemented]

# storage

- label: serve reads S3 endpoint bucket region access key and secret from configuration
  command: grep -q 'OPENPUFFER_S3' src/config.rs && grep -q 's3_endpoint' src/config.rs
  tags: [implemented]
- label: per-namespace objects live under s3://{bucket}/openpuffer/{namespace}/ with meta wal and index subtrees
  command: grep -q 'ROOT_PREFIX' src/models.rs && grep -q 'meta.json' src/meta.rs && grep -q 'wal/' src/wal.rs
  tags: [implemented]

# api

- label: GET /health returns 200 when the process is ready
  command: grep -q '/health' src/api.rs && grep -q '"ok"' src/api.rs
  tags: [implemented]
- label: GET /v1/namespaces and GET /v1/namespaces/{name} expose index_cursor and wal_commit_seq
  command: grep -q '/v1/namespaces' src/api.rs && grep -q 'index_cursor' src/meta.rs
  tags: [implemented]
- label: GET /health?deep=1 probes S3 and returns degraded when unavailable
  command: grep -q 'deep_health_probe' src/storage.rs && grep -q 'probe_s3_storage' src/health.rs
  tags: [implemented]
- label: GET /v1/namespaces/{name} exposes approx_row_count index_status and unindexed_bytes
  command: grep -q 'approx_row_count' src/models.rs && grep -q 'IndexStatus' src/models.rs
  tags: [implemented]
- label: POST /v2/namespaces/{name} accepts upsert_rows upsert_columns deletes patches and delete_by_filter
  command: grep -q 'write_namespace' src/api.rs && grep -q 'upsert_rows' src/models.rs
  tags: [implemented]
- label: POST /v2/namespaces/{name}/query runs vector FTS hybrid and filtered rank_by queries
  command: grep -q '/query' src/api.rs && grep -q 'execute_query' src/search.rs
  tags: [implemented]
- label: POST /v1/namespaces/{name}/warm prefetches index segments and pins NamespaceView
  command: test -f src/warm.rs && grep -q '/warm' src/api.rs
  tags: [implemented]
- label: GET and POST /v1/namespaces/{name}/export paginate WAL snapshot at wal_commit_seq
  command: test -f src/export.rs && grep -q '/export' src/api.rs
  tags: [implemented]
- label: DELETE /v2/namespaces/{name} removes a namespace and its S3 prefix objects
  command: grep -q 'delete_namespace' src/api.rs && grep -q 'delete_objects' src/storage.rs
  tags: [implemented]

