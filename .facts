# project

- label: project has Rust Cargo workspace skeleton and gitignore
  command: test -f Cargo.toml && test -f .gitignore && test -f src/main.rs && test -f src/lib.rs
  tags: [implemented]

# product

- label: release v0.3.0 is documented in CHANGELOG.md and Cargo.toml with v0.2.0 history retained
  command: grep -q 'version = "0.3.0"' Cargo.toml && test -f CHANGELOG.md && grep -q '## \[0.3.0\]' CHANGELOG.md && grep -q '## \[0.2.0\]' CHANGELOG.md && git rev-parse v0.2.0^{} >/dev/null
  tags: [implemented]
- label: Cargo package and binary are named openpuffer
  command: grep -qE 'name = "openpuffer"' Cargo.toml && test -f target/release/openpuffer || cargo build --release -q && test -f target/release/openpuffer
  tags: [implemented]
- label: core API targets turbopuffer-compatible write and query semantics
  command: grep -q "turbopuffer-compatible" src/lib.rs && test -f docs/ARCHITECTURE.md
  tags: [implemented]

# domain

- label: a Namespace is an isolated document collection keyed by name under S3 prefix openpuffer/{name}/
  command: grep -q 'ROOT_PREFIX' src/models.rs && test -f src/meta.rs && test -f src/namespace.rs
  tags: [implemented]
- label: a Document is a row with id and JSON attributes including optional vector and text fields
  command: grep -q 'struct Document' src/models.rs && grep -q 'attributes' src/models.rs
  tags: [implemented]
- label: durable state is WAL segments meta.json and index segments only with no per-doc docs/{id}.json
  command: test -f src/wal.rs && grep -q 'docs/{id}.json' docs/ARCHITECTURE.md && grep -q 'assert_wal_layout_after_write' tests/integration_s3.rs
  tags: [implemented]

# architecture

- label: release build produces one openpuffer static binary with no sidecar requirement
  command: cargo build --release -q && test -x target/release/openpuffer
  tags: [implemented]
- label: server persists all durable namespace state to S3-compatible object storage not embedded databases
  command: grep -rq 'put_object' src/ && ! grep -rq 'sqlite\|rocksdb\|sled' src/ && grep -q 'wal/' docs/ARCHITECTURE.md
  tags: [implemented]
- label: multiple serve instances can read the same bucket with optional local index cache only
  command: grep -q 'stateless' src/lib.rs && test -f src/cache.rs && test -f src/view_cache.rs
  tags: [implemented]
- label: meta.json and indexer commits use S3 conditional PUT If-Match and If-None-Match CAS
  command: grep -q 'if_match' src/namespace.rs && grep -q 'if_none_match' src/namespace.rs && grep -q 'if_match' src/indexer.rs
  tags: [implemented]
- label: writes append bincode WAL files at openpuffer/{ns}/wal/{seq:08}.bin before HTTP ACK
  command: test -f src/wal.rs && test -f src/buffer.rs && grep -q 'wal/{seq:08}.bin' src/wal.rs
  tags: [implemented]
- label: WAL segments encode v1 wire format 0x01 byte bincode payload and ieee crc32 trailer on write
  command: grep -q 'WAL_FORMAT_CRC32' src/wal.rs && cargo test --lib wal_roundtrip_serialize -q
  tags: [implemented]
- label: serve accepts OPENPUFFER_WAL_CORRUPT_POLICY fail or skip on corrupt WAL segment replay
  command: grep -q 'OPENPUFFER_WAL_CORRUPT_POLICY' src/config.rs && cargo test --lib wal_corrupt_policy_skip_returns_none -q
  tags: [implemented]
- label: integration test corrupt_wal_segment_on_minio_fail_and_skip_policies corrupts wal bytes on S3 and asserts fail vs skip replay
  command: cargo test -F integration --test integration_s3 corrupt_wal_segment_on_minio_fail_and_skip_policies -q
  tags: [implemented]
- label: background indexer merges WAL into FTS vector and filter segments under openpuffer/{ns}/index/
  command: test -f src/indexer.rs && test -f src/index/fts.rs && test -f src/index/vector.rs && test -f src/index/filter.rs
  tags: [implemented]
- label: per-namespace commit_lock serializes concurrent WAL appends and meta CAS for one namespace
  command: test -f src/commit_lock.rs && grep -q 'commit_lock' src/namespace.rs
  tags: [implemented]
- label: vector ANN index uses two-level centroids-l0.bin and centroids-l1-* segments on S3
  command: grep -q 'CentroidIndexL0' src/index/vector.rs && grep -q 'centroids-l1' src/index/vector.rs && cargo test --lib recall_at_10_1k_docs_32dim_above_point_seven -q
  tags: [implemented]
- label: WAL compaction writes wal/snapshot.bin CAS wal_snapshot_seq and prunes superseded wal segments
  command: test -f src/wal_compaction.rs && grep -q 'maybe_compact_wal' src/indexer.rs
  tags: [implemented]
- label: cold namespace load uses plan_cold_query probed L1 and clusters with storage_roundtrips in query performance
  command: test -f src/s3_batch.rs && grep -q 'plan_cold_query' src/s3_batch.rs && grep -q 'fetch_cold_vector_probed' src/s3_batch.rs && cargo test --lib query_performance_includes_storage_roundtrips -q
  tags: [implemented]
- label: vector index build uses k-means++ centroid initialization and namespace distance_metric in Lloyd iterations
  command: grep -q 'kmeans_plus_plus_init' src/index/vector.rs && cargo test --lib kmeans_plus_plus_differs_from_first_k_seeds -q
  tags: [implemented]
- label: serve and indexer accept OPENPUFFER_ANN_COARSE_PROBE and OPENPUFFER_ANN_FINE_PROBE written into centroids-l0.bin
  command: grep -q 'OPENPUFFER_ANN_COARSE_PROBE' src/config.rs && grep -q 'probe_coarse' src/index/vector.rs
  tags: [implemented]
- label: BackgroundIndexer fair round-robin schedules lagging namespaces with per-tick time slices
  command: grep -q 'fair round-robin' src/indexer.rs && cargo test -F integration --test integration_s3 fair_multi_namespace_background_indexer -q
  tags: [implemented]
- label: namespace meta supports at most two vector_fields with per-field centroids-l0 and cluster segments on S3
  command: grep -q 'MAX_VECTOR_FIELDS' src/meta.rs && cargo test -F integration --test integration_s3 two_vector_columns_query_each_field -q
  tags: [implemented]
- label: docs ARCHITECTURE.md includes three mermaid sequence diagrams for write path background index and cold query
  command: grep -c sequenceDiagram docs/ARCHITECTURE.md | grep -qx 3
  tags: [implemented]

# write

