  tags: [spec, ann, implemented]
- label: SPFresh incremental maintenance four 5k waves 20k docs no cluster over 512 recall at least 0.80
  command: grep -q 'fn spfresh_incremental_four_waves_20k_without_forced_rebuild' src/index/vector.rs && cargo test --lib spfresh_incremental_four_waves_20k_without_forced_rebuild -q
  tags: [spec, ann, implemented]
- label: ANN re-rank with OPENPUFFER_ANN_RERANK recall@10 at least 0.92 on 10k synthetic fixture
  command: grep -q 'OPENPUFFER_ANN_RERANK' src/config.rs && grep -q 'fn recall_at_10_10k_with_rerank_at_least_point_nine_two' src/index/vector.rs && cargo test --lib recall_at_10_10k_with_rerank_at_least_point_nine_two -q
  tags: [spec, ann, implemented]
- label: POST /v1/namespaces/{name}/recall returns JSON with numeric avg_recall avg_ann_count avg_exhaustive_count
