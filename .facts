  tags: [spec, ann, implemented]
- label: runtime ANN probe plan clamps absurd on-disk probes to OPENPUFFER_ANN_MAX_PROBE_CLUSTERS cluster bound
  command: grep -q 'OPENPUFFER_ANN_MAX_PROBE_CLUSTERS' src/config.rs && grep -q 'fn absurd_on_disk_probes_clamp_to_default_cluster_cap' src/index/vector.rs && cargo test --lib absurd -q
  tags: [spec, ann, implemented]

# query/cold

- label: cold vector query S3 cluster GET count is bounded by probe plan not num_fine_total
  command: grep -q 'fn cold_vector_query_cluster_gets_bounded_by_probe_plan' tests/integration_s3.rs && cargo test -F integration cold_vector_query_cluster_gets_bounded_by_probe_plan -q --test integration_s3
  tags: [spec, cold, implemented]
- label: cold hybrid Sum vector BM25 filter on 10k loads FTS in bootstrap round 2 with storage_roundtrips at most 4
  command: grep -q 'fn cold_hybrid_10k_fts_vector_filter_on_minio' tests/integration_s3.rs && cargo test -F integration cold_hybrid_10k_fts_vector_filter_on_minio -q --test integration_s3
  tags: [spec, cold, implemented]
- label: nightly bench_cold_100k recall@10 at least 0.88 and candidates_ratio below 0.20
  command: python3 -c "import json; d=json.load(open('benchmarks/results/nightly-100k.json')); assert d['benchmark']=='cold_100k' and d['recall_at_10']>=0.88 and d['candidates_ratio']<0.20 and d['storage_roundtrips']<=4" && grep -q 'async fn bench_cold_100k_nightly' tests/bench_cold.rs && grep -A2 'bench_cold_100k_nightly' tests/bench_cold.rs | grep -q '#\[ignore'
  tags: [spec, cold, bench, implemented]
- label: strong caught-up cold query on 10k namespace reports storage_roundtrips at most 4
  command: cargo test -F bench bench_cold_10k_storage_roundtrips_at_most_four -q --test bench_cold
  tags: [spec, cold, implemented]
- label: bench_cold_10k_warm_vs_cold compares probed cold S3 keys vs warm cache zero segment GETs
  command: grep -q 'async fn bench_cold_10k_warm_vs_cold' tests/bench_cold.rs && cargo test -F bench bench_cold_10k_warm_vs_cold -q --test bench_cold
  tags: [spec, cold, bench, implemented]
- label: eventual cold query on caught-up 10k reports cold_s3_keys_fetched and skips WAL tail exhaustive scan
  command: grep -q 'consistency.*eventual' tests/bench_cold.rs && grep -q 'bench_cold_10k_warm_vs_cold' tests/bench_cold.rs && cargo test -F bench bench_cold_10k_warm_vs_cold -q --test bench_cold
  tags: [spec, cold, implemented]
- label: plan_cold_query round3 keys are 8 to 64 not num_fine_total when num_fine_total is 4000
  command: cargo test --lib plan_cold_query_round3_bounded_at_4k_fine_total -q
  tags: [spec, cold, implemented]
- label: OPENPUFFER_COLD_MAX_KEYS_PER_ROUND sub-batches parallel GETs within one storage_roundtrip
  command: grep -q 'OPENPUFFER_COLD_MAX_KEYS_PER_ROUND' src/s3_batch.rs && cargo test --lib cold_fetch_sub_batch_count_caps_parallel_gets -q && cargo test --lib plan_cold_query_500_round3_keys_one_roundtrip_unchanged -q
  tags: [spec, cold, implemented]
- label: POST /v1/debug/namespaces/{name}/cold-plan previews plan_cold_query without executing the query
  command: grep -q 'fn cold_plan_debug_endpoint_on_minio' tests/integration_s3.rs && grep -q 'build_cold_plan_debug' src/s3_batch.rs && grep -q '/cold-plan' src/api.rs && cargo test -F integration cold_plan_debug -q --test integration_s3
  tags: [spec, cold, implemented]

# plan

- label: PLAN Phase 0-C outcomes verified — manual check against committed benchmark artifacts and ann/cold facts (1M AWS still pending)
  command: test -f benchmarks/results/baseline-10k.json && test -f benchmarks/results/nightly-100k.json && test -f benchmarks/results/cold-50k-v3.json && test -f scripts/bench-1m.sh && test -f docs/PLAN_SPFRESH_AND_COLD_1M.md && ! test -f benchmarks/results/1m-aws.json && echo 'Manual verify: ls -l benchmarks/results/baseline-10k.json benchmarks/results/nightly-100k.json benchmarks/results/cold-50k-v3.json; facts check --tags "ann or cold"; 1M gate pending — run scripts/bench-1m.sh then commit benchmarks/results/1m-aws.json'
  tags: [plan, implemented]
