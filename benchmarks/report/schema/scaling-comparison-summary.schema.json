{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openpuffer.dev/benchmarks/report/schema/scaling-comparison-summary.schema.json",
  "title": "openpuffer vs turbopuffer scaling comparison summary",
  "description": "Dashboard-oriented summary generated by compare_op_scaling_to_tpuf.py (benchmarks/results/scaling-comparison-summary.json).",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "timestamp_utc",
    "git_commit",
    "tpuf_official",
    "openpuffer_measured",
    "fits",
    "extrapolations",
    "recommended_extrapolation",
    "canonical_extrapolation",
    "ratios",
    "confidence",
    "verdict_text"
  ],
  "properties": {
    "schema_version": {
      "const": "scaling_comparison_summary_v1"
    },
    "timestamp_utc": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "git_commit": {
      "type": "string",
      "minLength": 7
    },
    "tpuf_official": {
      "type": "object",
      "additionalProperties": true,
      "required": ["namespace_docs", "dimensions", "cold", "warm", "write_path"],
      "properties": {
        "namespace_docs": { "const": 10000000 },
        "dimensions": { "const": 1024 },
        "cold": { "$ref": "#/$defs/latency_triple" },
        "warm": { "$ref": "#/$defs/latency_triple" },
        "write_path": { "$ref": "#/$defs/tpuf_write_path" }
      }
    },
    "openpuffer_measured": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "artifact",
          "label",
          "path",
          "namespace_docs",
          "dimensions",
          "p50_ms",
          "p90_ms",
          "p99_ms"
        ],
        "properties": {
          "artifact": { "type": "string", "minLength": 1 },
          "label": { "type": "string", "minLength": 1 },
          "path": { "enum": ["cold", "warm"] },
          "namespace_docs": { "type": "integer", "minimum": 1 },
          "dimensions": { "const": 128 },
          "p50_ms": { "type": "integer", "minimum": 0 },
          "p90_ms": { "type": "integer", "minimum": 0 },
          "p99_ms": { "type": "integer", "minimum": 0 },
          "ingest_wall_secs": { "type": "number", "minimum": 0 },
          "docs_per_sec": { "type": "number", "minimum": 0 }
        }
      }
    },
    "fits": {
      "type": "object",
      "additionalProperties": false,
      "required": ["linear", "power_law"],
      "properties": {
        "linear": { "$ref": "#/$defs/fit_ab_r2" },
        "power_law": { "$ref": "#/$defs/fit_ab_r2" }
      }
    },
    "extrapolations": {
      "type": "object",
      "additionalProperties": false,
      "required": ["linear_10m_ms", "power_law_10m_ms"],
      "properties": {
        "linear_10m_ms": { "type": "integer", "minimum": 0 },
        "power_law_10m_ms": { "type": "integer", "minimum": 0 }
      }
    },
    "recommended_extrapolation": {
      "const": "linear",
      "description": "Canonical doc-count extrapolation model (matches canonical_extrapolation.model)."
    },
    "canonical_extrapolation": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "model",
        "namespace_docs",
        "dimensions",
        "p50_ms",
        "p50_10m_1024_sqrt_dim_ms",
        "ratio_vs_tpuf_cold"
      ],
      "properties": {
        "model": { "enum": ["linear", "power_law", "log_linear"] },
        "namespace_docs": { "const": 10000000 },
        "dimensions": { "const": 128 },
        "p50_ms": { "type": "integer", "minimum": 0 },
        "p50_10m_1024_sqrt_dim_ms": { "type": "integer", "minimum": 0 },
        "ratio_vs_tpuf_cold": { "type": "number", "minimum": 0 }
      }
    },
    "ratios": {
      "type": "object",
      "additionalProperties": { "type": "number" },
      "required": [
        "cold_10m_128_vs_tpuf_cold",
        "cold_100k_vs_tpuf_cold",
        "warm_10k_vs_tpuf_warm",
        "warm_100k_vs_tpuf_warm",
        "heuristic_10m_1024_vs_tpuf_cold",
        "ingest_docs_per_sec"
      ],
      "properties": {
        "ingest_docs_per_sec": {
          "type": "object",
          "additionalProperties": { "type": "number", "minimum": 0 },
          "minProperties": 3
        }
      }
    },
    "confidence": { "enum": ["low", "medium", "high"] },
    "verdict_text": { "type": "string", "minLength": 80 }
  },
  "$defs": {
    "fit_ab_r2": {
      "type": "object",
      "additionalProperties": false,
      "required": ["a", "b", "r2"],
      "properties": {
        "a": { "type": "number" },
        "b": { "type": "number" },
        "r2": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "latency_triple": {
      "type": "object",
      "additionalProperties": false,
      "required": ["p50_ms", "p90_ms", "p99_ms"],
      "properties": {
        "p50_ms": { "type": "integer", "minimum": 0 },
        "p90_ms": { "type": "integer", "minimum": 0 },
        "p99_ms": { "type": "integer", "minimum": 0 }
      }
    },
    "tpuf_write_path": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "reference_artifact",
        "commit_latency_ms_max",
        "source_url",
        "not_comparable_to_openpuffer"
      ],
      "properties": {
        "reference_artifact": { "const": "tpuf-official-reference.json" },
        "commit_latency_ms_max": { "type": "integer", "const": 200 },
        "writes_per_sec_per_namespace_claim": { "type": "integer", "const": 10000 },
        "writes_per_sec_per_namespace_claim_source_url": {
          "type": "string",
          "format": "uri"
        },
        "source_url": { "type": "string", "format": "uri" },
        "not_comparable_to_openpuffer": { "type": "string", "minLength": 20 }
      }
    }
  }
}